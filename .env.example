NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
# Supabase → Project Settings → API → JWT Secret (legacy HS256). Used to mint
# short-lived user-scoped tokens for the MCP server so RLS applies.
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-here
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_GOOGLE_GEMINI_API_KEY=your-gemini-api-key
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_EMAIL=mailto:team@grindproof.co
CRON_SECRET=your-cron-secret
RESEND_API_KEY=your-resend-api-key-here
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=
AI_MODEL=gemini-2.5-flash
